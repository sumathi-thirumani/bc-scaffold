#!/bin/bash

#######################################
# bc-scaffold - Git Repository Scaffolding Tool
# Helps developers setup git repositories with best practice templates
#######################################

VERSION="0.1.0"
SCRIPT_NAME="bc-scaffold"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATES_DIR="$SCRIPT_DIR/templates"

# Available template types
TEMPLATE_TYPES=("quality" "ci" "cd" "trivy")

#######################################
# Display welcome message
#######################################
show_welcome() {
    cat << 'EOF'
